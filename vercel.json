{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "frontend/dist/client",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/.well-known/api-catalog",
      "headers": [
        { "key": "Content-Type", "value": "application/linkset+json" },
        { "key": "Cache-Control", "value": "public, max-age=600" }
      ]
    },
    {
      "source": "/.well-known/mcp-registry-auth",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/asyncapi.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=600" }
      ]
    },
    {
      "source": "/media/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/executive-lounge.html",
      "destination": "/lounge",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/x402",
      "destination": "/api/well-known-x402"
    },
    {
      "source": "/.well-known/x402.json",
      "destination": "/api/well-known-x402"
    },
    {
      "source": "/openapi.json",
      "destination": "/api/openapi"
    },
    {
      "source": "/favicon.ico",
      "destination": "/images/the-concierge-logo.png"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/demo",
      "destination": "/demo.html"
    },
    {
      "source": "/integrations",
      "destination": "/integrations.html"
    },
    {
      "source": "/token",
      "destination": "/token.html"
    },
    {
      "source": "/token/transparency",
      "destination": "/token-transparency.html"
    },
    {
      "source": "/agent",
      "destination": "/agent.html"
    },
    {
      "source": "/agent/identity",
      "destination": "/agent-identity.html"
    },
    {
      "source": "/agent/endpoints",
      "destination": "/agent-endpoints.html"
    },
    {
      "source": "/agent/playground",
      "destination": "/agent-playground.html"
    },
    {
      "source": "/agent/discover",
      "destination": "/agent-discover.html"
    },
    {
      "source": "/agent/skills",
      "destination": "/agent-skills.html"
    },
    {
      "source": "/agent/token-pay",
      "destination": "/agent-token-pay.html"
    },
    {
      "source": "/agent/token-pay/onboard",
      "destination": "/agent-token-pay-onboard.html"
    },
    {
      "source": "/lounge",
      "destination": "/executive-lounge.html"
    },
    {
      "source": "/docs",
      "destination": "/docs.html"
    },
    {
      "source": "/docs/quickstart",
      "destination": "/docs-quickstart.html"
    },
    {
      "source": "/docs/builders",
      "destination": "/docs-builders.html"
    },
    {
      "source": "/docs/builders/case-study",
      "destination": "/docs-builders-case-study.html"
    },
    {
      "source": "/docs/pricing",
      "destination": "/docs-pricing.html"
    },
    {
      "source": "/docs/launch",
      "destination": "/docs-launch.html"
    },
    {
      "source": "/docs/payment/x402",
      "destination": "/docs-payment-x402.html"
    },
    {
      "source": "/docs/payment/mpp",
      "destination": "/docs-payment-mpp.html"
    },
    {
      "source": "/docs/payment/paysh",
      "destination": "/docs-payment-paysh.html"
    },
    {
      "source": "/docs/payment/token-pay",
      "destination": "/docs-payment-token-pay.html"
    },
    {
      "source": "/docs/corbits",
      "destination": "/docs-corbits.html"
    },
    {
      "source": "/docs/grok-build",
