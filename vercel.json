{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist/client",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/executive-lounge.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/x402",
      "destination": "/api/well-known-x402"
    },
    {
      "source": "/openapi.json",
      "destination": "/api/openapi"
    },
    {
      "source": "/favicon.ico",
      "destination": "/images/the-concierge-logo.png"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/docs",
      "destination": "/docs.html"
    },
    {
      "source": "/api/lounge-signal-publish",
      "destination": "/api/concierge?__lounge_resource=signal-publish"
    },
    {
      "source": "/api/lounge-signal-open",
      "destination": "/api/concierge?__lounge_resource=signal-open"
    },
    {
      "source": "/api/rwa-mint-sol",
      "destination": "/api/concierge?__lounge_resource=rwa-mint-sol"
    },
    {
      "source": "/",
      "destination": "/executive-lounge.html"
    }
  ]
}
