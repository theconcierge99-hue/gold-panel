      "destination": "/docs-integration-zauth.html"
    },
    {
      "source": "/docs/integration/metaplex",
      "destination": "/docs-integration-metaplex.html"
    },
    {
      "source": "/docs/integration/agent-card",
      "destination": "/docs-integration-agent-card.html"
    },
    {
      "source": "/docs/integration/privy",
      "destination": "/docs-integration-privy.html"
    },
    {
      "source": "/go/mppscan",
      "destination": "/api/mppscan-redirect"
    },
    {
      "source": "/docs/api/overview",
      "destination": "/docs-api-overview.html"
    },
    {
      "source": "/docs/api/concierge",
      "destination": "/docs-api-concierge.html"
    },
    {
      "source": "/docs/api/intel",
      "destination": "/docs-intel.html"
    },
    {
      "source": "/docs/api/agent-identity",
      "destination": "/docs-agent-identity.html"
    },
    {
      "source": "/docs/api/agent-readiness",
      "destination": "/docs-agent-readiness.html"
    },
    {
      "source": "/docs/api/security",
      "destination": "/docs-security.html"
    },
    {
      "source": "/docs/api/lounge",
      "destination": "/docs-api-lounge.html"
    },
    {
      "source": "/docs/playground",
      "destination": "/docs-playground.html"
    },
    {
      "source": "/docs/architecture",
      "destination": "/docs-architecture.html"
    },
    {
      "source": "/docs/agents",
      "destination": "/docs-agents.html"
    },
    {
      "source": "/docs/agent-identity",
      "destination": "/docs-agent-identity.html"
    },
    {
      "source": "/docs/intel",
      "destination": "/docs-intel.html"
    },
    {
      "source": "/.well-known/agent-card.json",
      "destination": "/api/well-known-agent-card"
    },
    {
      "source": "/",
      "destination": "/agent.html"
    }
  ]
}
