# Executive Lounge — environment template
# Copy:  cp .env.example .env.local  → fill values → npm run dev
# Never commit .env.local — see docs/configuration.md and SECURITY.md

# --- Concierge AI (required for chat) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Google AI Studio → Application restrictions → HTTP referrers:
#   https://your-domain.com/*   and   https://*.vercel.app/*

# --- Optional Concierge agent model: GLM-4.7 Flash (Z.ai free tier) ---
# Register at https://z.ai → API Keys. Used when client sends agentModel: "glm-4.7-flash".
# Falls back to Gemini if unset or on error. Image / trading-plan paths stay Gemini-only.
# GLM_API_KEY=your_zai_api_key_here
# ZAI_API_KEY=alias_for_GLM_API_KEY
# GLM_API_BASE_URL=https://api.z.ai/api/paas/v4

# --- Optional Concierge agent models: HYRE LLM Gateway ---
# Partner key from https://docs.hyreagent.fun/gateway/get-access (hyre_gw_*).
# Used when client sends agentModel: "hyre-deepseek-v4-flash" or "hyre-glm-4.7-flash".
# Falls back to Gemini if unset or on error. Image / trading-plan paths stay Gemini-only.
# HYRE_GATEWAY_KEY=your_hyre_gateway_key_here
# HYRE_GATEWAY_API_KEY=alias_for_HYRE_GATEWAY_KEY
# HYRE_GATEWAY_BASE_URL=https://gw.hyreagent.fun/api/inference/v1

# --- Site CORS (optional) ---
# Same Host as your domain is auto-allowed on Vercel. Add custom domains if needed.
# ALLOWED_ORIGINS=https://conc-exe.xyz,https://www.conc-exe.xyz
ALLOWED_ORIGINS=

# --- x402 micropayments (PayAI primary · Dexter fallback) ---
# Primary facilitator: https://facilitator.payai.network
# Fallback facilitator: https://x402.dexter.cash (free; OpenDexter auto-discovery)
# OpenDexter marketplace: https://dexter.cash/opendexter · claim profile: https://dexter.cash/sellers
#
# Optional — swap primary to Dexter only: X402_FACILITATOR=dexter
# PayAI docs: https://docs.payai.network/x402/facilitators/pricing
# Dexter docs: https://docs.dexter.cash/docs/facilitator-and-chains/
#
# Pricing model:
#   • Lounge headlines (/api/market) — FREE to browse
#   • Open one article (/api/news-open) — 0.1 USDC per click
#   • Open creator signal (/api/signal-open) — 0.1 USDC per unlock
#   • Publish creator signal (/api/lounge-signal-publish) — $0.02 minimum settlement (100% protocol)
#   • Creator rewards — Lounge points on publish (+25) and reader unlock (+10); no USDC revenue share
#   • Concierge chat (/api/concierge) — 0.1 USDC per message
#
# Creator signals storage (required in production):
#   Vercel → Storage → Redis (Upstash) or legacy KV — adds:
#   KV_REST_API_URL=...
#   KV_REST_API_TOKEN=...
#   (Upstash may use UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN instead)
#   Also powers Concierge LOUNGE MEMORY (headlines + creator signals for future answers)
#
# REQUIRED to enable payments (use YOUR wallet — not from PayAI):
#   X402_EVM_PAY_TO = your address on Base that receives USDC
#   (Phantom / OKX → Ethereum network on Base → copy address)
#   MUST be exactly: 0x + 40 hex characters (20 bytes). Example:
# X402_EVM_PAY_TO=0xYourBaseReceiveAddress40HexChars
#   WRONG: Solana address, 0x + 64 hex (66 chars = tx hash), or a transaction hash.
#   After deploy, https://your-domain/api/x402-config must show "enabled": true
#
# Optional — accept USDC on Solana too (users pay from whichever chain has funds):
# X402_SOL_PAY_TO=YourSolanaBase58ReceiveAddress
#   WRONG: private key / seed phrase (~88 chars) — never put secrets in Vercel.
# Users with only SOL USDC can pay on Solana; only Base USDC on EVM; both if connected.
#
# X402_ENABLED=true
# X402_FACILITATOR=payai
# X402_FACILITATOR=dexter
# X402_NETWORK_MODE=mainnet
# X402_NETWORK_MODE=testnet
#
# --- Privy embedded wallets (optional — Lounge login without extensions) ---
# https://dashboard.privy.io/ → App ID + Settings → Clients → Client ID
# Enable embedded Solana + Ethereum wallets; add your domain to allowed origins.
# PRIVY_APP_ID=your_privy_app_id
# PRIVY_CLIENT_ID=your_privy_client_id
#
# --- zauth Provider Hub (optional — x402 trust + telemetry) ---
# https://zauth.inc/provider-hub → API key → verified endpoints in zauth Database
# ZAUTH_API_KEY=your_zauth_provider_api_key
# ZAUTH_API_ENDPOINT=https://back.zauthx402.com
#
# PayAI API keys — NOT required to start (10,000 settlements/month free, no key).
# Only if you scale beyond that: https://merchant.payai.network → create API key
# PAYAI_API_KEY_ID=your-key-id
# PAYAI_API_KEY_SECRET=your_payai_secret_here
#
# Solana RPC for x402 + NFT mint proxy (server-only; browser uses /api/solana-rpc-send):
# Helius recommended. Do NOT use solana.drpc.org or rpc.ankr.com (free tier blocks blockhash).
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# If unset, production uses https://solana-rpc.publicnode.com
#
# Solana RWA NFT mint (Metaplex → creator wallet on publish):
# RWA_MINT_SOL_SECRET=base58_or_json_keypair_with_SOL_for_fees (ConcEx NFT / mint authority wallet)
# LOUNGE_INTERNAL_KEY=optional_bearer_for_internal_mint_routes
# RWA_MINT_INTERNAL_KEY=alias_if_LOUNGE_INTERNAL_KEY_unset
# RWA_SIGNAL_CONTRACT_SOL=optional_collection_mint_from_Metaplex_Studio
# See docs/rwa-solana-setup.md
#
# Optional — future Base ERC-1155:
# RWA_SIGNAL_CONTRACT_EVM=0xYourErc1155ContractOnBase
#
# Env names must be X402_EVM_PAY_TO and X402_SOL_PAY_TO (not PAY_ID).
# PAY_ID is accepted as alias if you already created those by mistake.
#
# x402scan (public discovery + on-chain index via facilitator settlements):
#   X402_SITE_ORIGIN=https://your-production-domain.com
#   Optional ownership proofs (comma-separated public EVM addresses only):
#   X402_OWNERSHIP_PROOFS=0xYourMerchantEvmAddress
# After deploy, register at https://www.x402scan.com/resources/register
# Discovery: https://your-domain/.well-known/x402 and https://your-domain/openapi.json
#
# MPPscan — copy the full server URL from your MPPscan server page after registering conc-exe.xyz:
# MPPSCAN_SERVER_URL=https://www.mppscan.com/server/YOUR_HASH_HERE
# Site links use https://your-domain/go/mppscan (302 to this URL, or /register if unset).
#
# SOON utility token (Token Pay default merchant)
# TOKEN_PAY_DEFAULT_MERCHANT=soon
# TOKEN_PAY_SOON_SYMBOL=SOON
# TOKEN_PAY_SOON_NAME=SOON
# TOKEN_PAY_SOON_COMING_SOON=SOON — not available yet. Will unlock after token launch.
# TOKEN_PAY_MERCHANTS_JSON=[{"id":"acme","symbol":"ACME","mint":"…","decimals":6,"payTo":"…","fallbackUsd":0.001,"resourceKinds":["external","concierge"],"allowedOrigins":["https://api.acme.xyz"]}]
# Partner onboarding: https://conc-exe.xyz/docs/payment/token-pay
# Pre-launch: leave SOON_TOKEN_MINT unset — token pay shows "Coming soon" in UI.
# Snapshots: config/launch/pre-launch.env.snapshot | post-launch.env.snapshot
#
# MCP Registry (phase 2 distribution — HTTP domain auth for xyz.conc-exe/*)
# MCP_REGISTRY_PRIVATE_KEY_HEX=64_char_ed25519_seed_hex
# Generate locally: npm run mcp-registry:generate-key
# Build emits /.well-known/mcp-registry-auth when set. See mcp-registry/PUBLISH.md
#
# Dev Lounge — wire = fresh local RSS; creator signals sync from production when KV unset
# DEV_CREATOR_SYNC=1
# DEV_CREATOR_SYNC_ORIGIN=https://conc-exe.xyz
# Or add KV_REST_API_URL + KV_REST_API_TOKEN (same as Vercel) for direct Redis access
# Playbook: docs/launch-playbook.md
# After pump.fun launch, set on Vercel:
# SOON_TOKEN_MINT=base58_mint_after_pump_fun_launch
# SOON_RESOURCE_KINDS=all
# SOON_TOKEN_DISCOUNT_PERCENT=30
# SOON_MINT=alias_for_SOON_TOKEN_MINT
# SOON_TOKEN_DECIMALS=6
# SOON_PRICE_SOURCE=dexscreener
# SOON_PRICE_MAX_AGE_SEC=60
# SOON_USDC_RATE=0.00008
# SOON_HOLDER_FREE_TIER_ENABLED=true
# SOON_HOLDER_FREE_RAW_PER_DAY=5
# SOON_HOLDER_MIN_TOKENS=50000
# TCX prepaid credits (MVP Resources — KV ledger, 1 credit = $0.01)
# TCX_CREDITS_ENABLED=true       # default on when TCX is live
# TCX_CREDITS_WELCOME=100        # one-time welcome bonus ($1.00)
# TCX_CREDITS_MIN_HOLD=1000000   # minimum TCX hold to use credits
# SOON_SECURITY_FREE_TIER_ENABLED=true
# SOON_SECURITY_SCOUT_FREE_PER_DAY=3
# SECURITY_REQUIRE_ALLOWLIST=true
# SECURITY_PLATFORM_DENY_HOSTS=
# SECURITY_DENY_HOST_SUFFIXES=
