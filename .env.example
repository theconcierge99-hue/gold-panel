# Executive Lounge — environment template
# Copy:  cp .env.example .env.local  → fill values → npm run dev
# Never commit .env.local — see docs/configuration.md and SECURITY.md

# --- Concierge AI (required for chat) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Google AI Studio → Application restrictions → HTTP referrers:
#   https://your-domain.com/*   and   https://*.vercel.app/*

# --- Site CORS (optional) ---
# Same Host as your domain is auto-allowed on Vercel. Add custom domains if needed.
# ALLOWED_ORIGINS=https://conc-exe.xyz,https://www.conc-exe.xyz
ALLOWED_ORIGINS=

# --- x402 micropayments (PayAI facilitator) ---
# https://docs.payai.network/x402/facilitators/pricing
#
# Pricing model:
#   • Lounge headlines (/api/market) — FREE to browse
#   • Open one article (/api/news-open) — 0.1 USDC per click
#   • Open creator signal (/api/signal-open) — 0.1 USDC per unlock
#   • Publish creator signal (/api/signal-publish) — 1 USDC anti-spam fee (100% merchant)
#   • Reader unlock revenue split — 80% creator / 20% merchant (monthly settlement; see signal-revenue.ts)
#   • Concierge chat (/api/concierge) — 0.1 USDC per message
#
# Creator signals storage (required in production):
#   Vercel → Storage → Redis (Upstash) or legacy KV — adds:
#   KV_REST_API_URL=...
#   KV_REST_API_TOKEN=...
#   (Upstash may use UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN instead)
#   Also powers Concierge LOUNGE MEMORY (headlines + creator signals for future answers)
#
# REQUIRED to enable payments (use YOUR wallet — not from PayAI):
#   X402_EVM_PAY_TO = your address on Base that receives USDC
#   (Phantom / OKX → Ethereum network on Base → copy address)
#   MUST be exactly: 0x + 40 hex characters (20 bytes). Example:
# X402_EVM_PAY_TO=0xYourBaseReceiveAddress40HexChars
#   WRONG: Solana address, 0x + 64 hex (66 chars = tx hash), or a transaction hash.
#   After deploy, https://your-domain/api/x402-config must show "enabled": true
#
# Optional — accept USDC on Solana too (users pay from whichever chain has funds):
# X402_SOL_PAY_TO=YourSolanaBase58ReceiveAddress
#   WRONG: private key / seed phrase (~88 chars) — never put secrets in Vercel.
# Users with only SOL USDC can pay on Solana; only Base USDC on EVM; both if connected.
#
# X402_ENABLED=true
# X402_NETWORK_MODE=mainnet
# X402_NETWORK_MODE=testnet
#
# PayAI API keys — NOT required to start (10,000 settlements/month free, no key).
# Only if you scale beyond that: https://merchant.payai.network → create API key
# PAYAI_API_KEY_ID=your-key-id
# PAYAI_API_KEY_SECRET=your_payai_secret_here
#
# Optional — Helius RPC (recommended; server-only, never exposed to the browser):
# Dashboard → RPC URL → Mainnet → copy full URL including api-key into Vercel only:
# SOLANA_RPC_URL=https://your-rpc-provider.example/?api-key=YOUR_RPC_KEY
#
# Env names must be X402_EVM_PAY_TO and X402_SOL_PAY_TO (not PAY_ID).
# PAY_ID is accepted as alias if you already created those by mistake.
#
# x402scan (public discovery + on-chain index via facilitator settlements):
#   X402_SITE_ORIGIN=https://your-production-domain.com
#   Optional ownership proofs (comma-separated public EVM addresses only):
#   X402_OWNERSHIP_PROOFS=0xYourMerchantEvmAddress
# After deploy, register at https://www.x402scan.com/resources/register
# Discovery: https://your-domain/.well-known/x402 and https://your-domain/openapi.json
#
# Note: X402_ACCESS_SECRET is NOT used (removed). Do not set it.
