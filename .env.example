# https://aistudio.google.com/apikey → Create API key (starts with AIza)
# Copy:  copy .env.example .env.local  → paste real key → restart npm run dev
GEMINI_API_KEY=AIzaSy_REPLACE_WITH_YOUR_KEY

# Production custom domain(s), comma-separated (required if not *.vercel.app)
# Example: ALLOWED_ORIGINS=https://conc-exp.xyz,https://www.conc-exp.xyz
ALLOWED_ORIGINS=

# Market data (free, server-side): Binance, Yahoo Finance, CoinGecko, DeFi Llama,
# Fear & Greed, Mempool.space, RSS headlines (CoinDesk, Bloomberg, Reuters, CoinTelegraph, The Block).
# General knowledge: Wikipedia, DuckDuckGo Instant Answers, world news RSS (BBC, NPR, Guardian).
# Bloomberg/Reuters = public RSS headlines only — not Bloomberg Terminal.
# Coinglass is PAID (~$29/mo) — not integrated; liq context uses Binance positioning.

# Google AI Studio → API key → Application restrictions:
#   HTTP referrers: your-domain.com/*  and  *.vercel.app/*
# Never commit .env.local — already in .gitignore
